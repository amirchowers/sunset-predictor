# Sunset Predictor — Environment Variables
# Copy this file to .env and fill in your values.
# All keys are optional — the predictor works without them.

# Telegram notifications (from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Vision AI — Gemini (primary rater)
# Get a free key at https://aistudio.google.com/
GEMINI_API_KEY=

# Vision AI — HuggingFace (fallback rater)
# Get a free token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Instagram auto-posting
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
